{
  "name": "memq-nightly",
  "description": "Full nightly matrix with public tracks when adapter commands are configured.",
  "tasks": [
    "cross-session-release-image",
    "manual-copy-regression",
    "protocol-tool-discipline"
  ],
  "repetitions": 2,
  "matrix": {
    "tracks": ["fixture", "local_cli", "antigravity"],
    "conditions": [
      "stateless",
      "naive_memory",
      "memq_core",
      "memq_accelerated"
    ]
  },
  "model": {
    "name": "pinned-model-required",
    "provider": "external",
    "temperature": 0
  },
  "memq": {
    "url": "http://127.0.0.1:8000/mcp/v1",
    "timeoutMs": 8000
  },
  "accelerated": {
    "enabled": true,
    "contextBudgetTokens": 4096,
    "segmentTokens": 2048,
    "soulJournalPath": "fixtures/soul-journal/memq.jsonl",
    "graphitiUrl": "http://127.0.0.1:8082/mcp/v1",
    "qdrantUrl": "http://127.0.0.1:6333"
  },
  "outputDir": "artifacts/results"
}
